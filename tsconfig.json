{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "types/*": ["src/types/*"],
      "src/*": ["src/*"]
    }
    // "esModuleInterop": true
    /* Additional Checks */
    // "noImplicitReturns": true, /* Report error when not all code paths in function return a value. */
    // "noFallthroughCasesInSwitch": true, /* Report errors for fallthrough cases in switch statement. */
    // "noUnusedParameters": true,  /* Report errors on unused parameters. */
  },
  // The client (client/) is a separate Figma plugin with its own tsconfig and
  // Rollup build; keep it out of the backend's TypeScript program.
  "exclude": ["node_modules", "client", "dist", "out"]
}
